# ============================================================================
# Web Reader - Canonical Environment Configuration
# ============================================================================
# Copy this file to .env and customize values for your environment.
# Root .env is the single source of truth for all services.

# ==========================================================================
# URLs (Required)
# ==========================================================================
FRONTEND_PUBLIC_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8000
BACKEND_INTERNAL_URL=http://backend:8000
LANGCHAIN_INTERNAL_URL=http://langchain:8001
FASTMCP_INTERNAL_URL=http://fastmcp:3100/mcp
PLAYWRIGHT_WS_URL=ws://playwright:3002
OLLAMA_BASE_URL=http://ollama:11434
VITE_API_URL=/api
VITE_WS_URL=ws://localhost:3000
INTERNAL_API_URL=http://backend:8000

# ==========================================================================
# General
# ==========================================================================
NODE_ENV=development
LOG_LEVEL=info
LOG_TARGET=console
LOG_FILE=logs/app.log

# ==========================================================================
# Frontend
# ==========================================================================
FRONTEND_PORT=3000
VITE_LOG_LEVEL=info
VITE_LOG_TARGET=console
VITE_POLL_INTERVAL_MS=1500

# ==========================================================================
# Backend API
# ==========================================================================
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT=300
ARTIFACT_DIR=artifacts

# ==========================================================================
# LangChain
# ==========================================================================
LANGCHAIN_HOST=0.0.0.0
LANGCHAIN_PORT=8001
AGENT_MAX_ITERATIONS=15
AGENT_MAX_EXECUTION_TIME=300
AGENT_TEMPERATURE=0.0
AGENT_VERBOSE=true
MAX_LINK_DEPTH=3
MAX_PAGES=20
TIME_BUDGET=120

# ==========================================================================
# FastMCP
# ==========================================================================
MCP_SERVER_PORT=3100
HEALTH_SERVER_PORT=3101
FASTMCP_HEALTH_PORT=3101
PLAYWRIGHT_HOST=playwright
PLAYWRIGHT_PORT=3002
BROWSER_TYPE=chromium
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW=90
REQUEST_DELAY_MIN=10
REQUEST_DELAY_MAX=20
RESPECT_ROBOTS_TXT=true
MAX_BROWSER_CONTEXTS=5
MAX_TEXT_CHARS=10000
MAX_LINKS=50
OUTPUT_WEBPAGE=false

# ==========================================================================
# Ollama
# ==========================================================================
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_CONTEXT_LENGTH=131072
OLLAMA_KEEP_ALIVE=24h
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_QUEUE=2

# ==========================================================================
# Data and runtime
# ==========================================================================
DEFAULT_TIMEOUT=120
WAIT_UNTIL=networkidle
DATA_DIR=./data
LOGS_DIR=./logs
CONFIG_DIR=./config
DATA_RETENTION_DAYS=30
