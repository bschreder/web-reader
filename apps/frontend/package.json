{
  "name": "web-reader-frontend",
  "version": "0.1.0",
  "description": "Web Reader frontend - TanStack Start SPA/SSR with real-time task monitoring",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite dev",
    "dev:debug": "node --inspect=0.0.0.0:9229 node_modules/vite/bin/vite.js dev",
    "build": "vite build",
    "build:clean": "del-cli dist && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest --coverage",
    "test:clean": "del-cli dist && npm run test:coverage",
    "test:unit": "vitest run --project=unit --coverage",
    "test:browser": "vitest run --project=browser",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/start": "^1.120.20",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@rollup/rollup-win32-x64-msvc": "^4.60.4",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/devtools-vite": "^0.6.1",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/react-start": "^1.168.17",
    "@tanstack/router-cli": "^1.167.12",
    "@tanstack/router-devtools": "^1.167.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/browser-preview": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "del-cli": "^7.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7",
    "vitest-browser-react": "^2.2.0"
  }
}
