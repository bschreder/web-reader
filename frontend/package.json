{
  "name": "web-reader-frontend",
  "version": "0.1.0",
  "description": "Web Reader frontend - TanStack Start SPA/SSR with real-time task monitoring",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite dev",
    "dev:debug": "node --inspect=0.0.0.0:9229 node_modules/vite/bin/vite.js dev",
    "build": "vite build",
    "build:clean": "del-cli ~/frontend/dist && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest --coverage",
    "test:clean": "del-cli ~/frontend/dist && npm run test:coverage",
    "test:unit": "vitest run --project=unit --coverage",
    "test:browser": "vitest run --project=browser --coverage",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.157.18",
    "@tanstack/start": "^1.120.20",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/devtools-vite": "^0.5.0",
    "@tanstack/eslint-plugin-router": "^1.155.0",
    "@tanstack/react-devtools": "^0.9.4",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-start": "^1.157.18",
    "@tanstack/router-cli": "^1.157.18",
    "@tanstack/router-devtools": "^1.157.18",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/browser-preview": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "playwright": "^1.58.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.0.5"
  }
}
