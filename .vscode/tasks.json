{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start (Production)",
      "type": "shell",
      "command": "pwsh -File ${workspaceFolder}/infra/scripts/wr.ps1 up --build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Start (Debug)",
      "type": "shell",
      "command": "pwsh -File ${workspaceFolder}/infra/scripts/wr.ps1 debug up --build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Stop",
      "type": "shell",
      "command": "pwsh -File ${workspaceFolder}/infra/scripts/wr.ps1 down",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Stop + Prune",
      "type": "shell",
      "command": "pwsh -Command \"& { pwsh -File ${workspaceFolder}/infra/scripts/wr.ps1 down; docker system prune -f; docker volume prune -f }\"",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Start Infrastructure",
      "type": "shell",
      "command": "pwsh -File ${workspaceFolder}/infra/scripts/wr.ps1 up --infra --build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Stop Infrastructure",
      "type": "shell",
      "command": "pwsh -File ${workspaceFolder}/infra/scripts/wr.ps1 down --infra",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
